; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be manually edited just fine.

config_version=5

[application]

config/name="Time Loop Detective"
config/description="A 2D simulation detective game where the same day repeats every 10 minutes."
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

EventBus="*res://autoloads/event_bus.gd"
GameState="*res://autoloads/game_state.gd"
SaveManager="*res://autoloads/save_manager.gd"
TimeManager="*res://autoloads/time_manager.gd"
CrimeEngine="*res://autoloads/crime_engine.gd"
AudioManager="*res://autoloads/audio_manager.gd"
TransitionManager="*res://autoloads/transition_manager.gd"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="viewport"

[gui]

theme/default_font_size=8

